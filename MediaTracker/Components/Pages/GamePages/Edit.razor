@page "/games/edit"
@using Microsoft.EntityFrameworkCore
@using MediaTracker.Models
@inject IDbContextFactory<MediaTracker.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Game</h2>
<hr />
@if (Game is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Game" OnValidSubmit="UpdateGame" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="Game.Id" value="@Game.Id" />
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="title" class="form-label">Title:</label>
                    <InputText id="title" @bind-Value="Game.Title" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => Game.Title" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="genre" class="form-label">Genre:</label>
                    <InputText id="genre" @bind-Value="Game.Genre" class="form-control" />
                    <ValidationMessage For="() => Game.Genre" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="finished" class="form-label">Finished:</label>
                    <InputCheckbox id="finished" @bind-Value="Game.Finished" class="form-check-input" />
                    <ValidationMessage For="() => Game.Finished" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="rating" class="form-label">Rating:</label>
                    <InputSelect id="rating" @bind-Value="Game.Rating" class="form-control">
                        <option value="">-- None --</option>
                        @for (int i = 1; i <= 10; i++)
                        {
                            <option value="@i">@i</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => Game.Rating" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="notes" class="form-label">Notes:</label>
                    <InputTextArea id="notes" @bind-Value="Game.Notes" class="form-control" Rows="6" />
                    <ValidationMessage For="() => Game.Notes" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/games">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    [SupplyParameterFromForm]
    private Game? Game { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Game ??= await context.Game.FirstOrDefaultAsync(m => m.Id == Id);

        if (Game is null)
        {
            NavigationManager.NotFound();
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateGame()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(Game!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!GameExists(Game!.Id))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/games");
    }

    private bool GameExists(int id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Game.Any(e => e.Id == id);
    }
}
